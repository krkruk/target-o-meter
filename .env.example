# ---------------------------------------------------------------------------
# Existing (CV / LLM)
# ---------------------------------------------------------------------------

GOOGLE_API_KEY=key_i_need_some_computer_vision_skills_and_im_too_dumb_to_implement_an_algorithm_of_my_own
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:latest

# ---------------------------------------------------------------------------
# F-01: OAuth + Roles scaffold (Auth0 OIDC BFF)
# ---------------------------------------------------------------------------

# Auth0 OIDC client. Leave empty in dev — the dev-bypass middleware makes
# Auth0 optional locally (Phase 4). Required for the real OAuth flow.
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_DOMAIN=your-tenant.eu.auth0.com

# The single source of truth for the Owner role. ``User.role`` derives Owner
# by comparing ``self.sub == OWNER_SUB_ID`` (never persisted). Empty → fails
# closed (no one is Owner); W001 warns in prod.
# IMPERSONATION (dev only): set DEV_AUTH_BYPASS_SUB equal to this value to
# log in locally AS the Owner without touching Auth0.
OWNER_SUB_ID=

# Dev-only auth bypass: when set AND DEBUG=True, every request is authenticated
# as this sub's user (Phase 4 middleware). target_o_meter.E001 refuses to boot
# if this is set while DEBUG=False. DO NOT set in production.
DEV_AUTH_BYPASS_SUB=

# Seeded dev admin (Django admin login). Dev-only. ``create_superuser``
# requires a usable password here.
DEV_ADMIN_SUB=
DEV_ADMIN_NICK=dev-admin
DEV_ADMIN_PASSWORD=

# Cookie SECURE flag toggle. False in dev (no HTTPS on localhost); True in prod.
SECURE_COOKIES=False

# Django core (already read by settings.py).
# DEBUG=True in dev; False in prod (E001 guards the dev-bypass under DEBUG=False).
# SECRET_KEY=<generate one for prod>
# ALLOWED_HOSTS=your-domain.example.com
